#pragma once

// The numeric version format is AAAAABBBBBCCCCCDDDE where:
//
// AAAAA - major version number
// BBBBB - minor version number
// CCCCC - bugfix version number
// DDD   - alpha / beta (DDD + 500) version number
// E     - final (0) / snapshot (1)
//
// When DDDE is not 0, 1 is subtracted from AAAAABBBBBCCCCC. For example:
//
// Version      AAAAABBBBBCCCCCDDDE
//
// 0.1.0        0000000001000000000
// 0.1.2        0000000001000020000
// 1.2.3        0000100002000030000
// 2.2.0-a.1    0000200001999990010
// 3.0.0-b.2    0000299999999995020
// 2.2.0-a.1.z  0000200001999990011
//
#define LIBFORGE_VERSION       $libforge.version.project_number$ULL
#define LIBFORGE_VERSION_STR   "$libforge.version.project$"
#define LIBFORGE_VERSION_ID    "$libforge.version.project_id$"
#define LIBFORGE_VERSION_FULL  "$libforge.version$"

#define LIBFORGE_VERSION_MAJOR $libforge.version.major$
#define LIBFORGE_VERSION_MINOR $libforge.version.minor$
#define LIBFORGE_VERSION_PATCH $libforge.version.patch$

#define LIBFORGE_PRE_RELEASE   $libforge.version.pre_release$

#define LIBFORGE_SNAPSHOT_SN   $libforge.version.snapshot_sn$ULL
#define LIBFORGE_SNAPSHOT_ID   "$libforge.version.snapshot_id$"
